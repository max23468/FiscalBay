[Unit]
Description=FiscalBay periodic reconciliation

[Service]
Type=oneshot
User=__APP_USER__
Group=__APP_GROUP__
WorkingDirectory=__APP_DIR__
ExecStart=/usr/bin/bash -lc 'source "__VENV_DIR__/bin/activate" && set -a && source "__ENV_FILE__" && set +a && exec /usr/bin/bash "__APP_DIR__/deploy/reconcile.sh"'
