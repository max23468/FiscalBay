EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REFRESH_TOKEN=
EBAY_ENVIRONMENT=production
EBAY_SCOPES=https://api.ebay.com/oauth/api_scope/sell.fulfillment.readonly

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_NOTIFY_CHAT_IDS=

